# Xroads Supabase environment template
# Copy this file to `.env.local` and fill in the real values for your project.

# Client-side values exposed to the Vite app
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Shared Supabase values for local scripts, server-side code, or future backend jobs
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_JWT_SECRET=your-jwt-secret

# Standard Postgres connection string for Supabase migrations and tooling
DATABASE_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres
